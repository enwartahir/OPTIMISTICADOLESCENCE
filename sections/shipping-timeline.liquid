{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .shipping-timeline__heading {
    font-size: 3.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 1.2rem;
    text-align: center;
  }

  .shipping-timeline__subtext {
    font-size: 1.5rem;
    line-height: 1.7;
    margin-bottom: 5rem;
    text-align: center;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .shipping-timeline__steps {
    display: flex;
    justify-content: center;
    align-items: flex-start;
    gap: 0;
    position: relative;
    flex-wrap: nowrap;
  }

  .shipping-timeline__step {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    flex: 1;
    position: relative;
  }

  .shipping-timeline__step-connector {
    position: absolute;
    top: 2.2rem;
    left: 50%;
    width: 100%;
    height: 2px;
    background: rgba(var(--color-foreground), 0.15);
    z-index: 0;
  }

  .shipping-timeline__step:last-child .shipping-timeline__step-connector {
    display: none;
  }

  .shipping-timeline__step-icon {
    width: 4.8rem;
    height: 4.8rem;
    border-radius: 50%;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2rem;
    position: relative;
    z-index: 1;
    margin-bottom: 1.6rem;
    flex-shrink: 0;
  }

  .shipping-timeline__step-title {
    font-size: 1.4rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin-bottom: 0.6rem;
  }

  .shipping-timeline__step-duration {
    font-size: 1.2rem;
    line-height: 1.5;
    margin: 0;
  }

  .shipping-timeline__note {
    text-align: center;
    font-size: 1.2rem;
    opacity: 0.5;
    margin-top: 4rem;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .shipping-timeline__steps {
      flex-direction: column;
      align-items: center;
      gap: 0;
    }

    .shipping-timeline__step {
      flex-direction: row;
      text-align: left;
      gap: 2rem;
      width: 100%;
      max-width: 360px;
      padding-bottom: 2.4rem;
    }

    .shipping-timeline__step-connector {
      top: 0;
      left: 2.4rem;
      width: 2px;
      height: 100%;
    }

    .shipping-timeline__step-icon {
      margin-bottom: 0;
      flex-shrink: 0;
    }

    .shipping-timeline__heading {
      font-size: 2.4rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">

    <h2 class="shipping-timeline__heading">{{ section.settings.heading }}</h2>
    <p class="shipping-timeline__subtext">{{ section.settings.subtext }}</p>

    <div class="shipping-timeline__steps">

      <div class="shipping-timeline__step">
        <div class="shipping-timeline__step-connector"></div>
        <div class="shipping-timeline__step-icon">🧾</div>
        <div>
          <p class="shipping-timeline__step-title">Order Placed</p>
          <p class="shipping-timeline__step-duration">Instant confirmation email sent to you</p>
        </div>
      </div>

      <div class="shipping-timeline__step">
        <div class="shipping-timeline__step-connector"></div>
        <div class="shipping-timeline__step-icon">⚙️</div>
        <div>
          <p class="shipping-timeline__step-title">Processing</p>
          <p class="shipping-timeline__step-duration">1 - 2 business days</p>
        </div>
      </div>

      <div class="shipping-timeline__step">
        <div class="shipping-timeline__step-connector"></div>
        <div class="shipping-timeline__step-icon">📦</div>
        <div>
          <p class="shipping-timeline__step-title">Dispatched</p>
          <p class="shipping-timeline__step-duration">Tracking number emailed to you</p>
        </div>
      </div>

      <div class="shipping-timeline__step">
        <div class="shipping-timeline__step-connector"></div>
        <div class="shipping-timeline__step-icon">✈️</div>
        <div>
          <p class="shipping-timeline__step-title">In Transit</p>
          <p class="shipping-timeline__step-duration">7 - 14 business days internationally</p>
        </div>
      </div>

      <div class="shipping-timeline__step">
        <div class="shipping-timeline__step-connector"></div>
        <div class="shipping-timeline__step-icon">🏠</div>
        <div>
          <p class="shipping-timeline__step-title">Delivered</p>
          <p class="shipping-timeline__step-duration">Straight to your door</p>
        </div>
      </div>

    </div>

    <p class="shipping-timeline__note">{{ section.settings.note }}</p>

  </div>
</div>

{% schema %}
{
  "name": "Shipping Timeline",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "How Long Will It Take?"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Here's what happens after you place your order with INTLFans."
    },
    {
      "type": "text",
      "id": "note",
      "label": "Bottom Note",
      "default": "Delivery times are estimates and may vary depending on your location and local customs. All orders are fully tracked."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Shipping Timeline"
    }
  ]
}
{% endschema %}