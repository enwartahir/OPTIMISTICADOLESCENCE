  }
}
</style>
<script>
(function() {
  var targetDate = new Date('{{ section.settings.target_date }}T{{ section.settings.target_time }}:00').getTime();

  function flipTo(digitEl, newNum) {
    var base = digitEl.querySelector('.base');
    var current = base.textContent.trim();
    var newStr = String(newNum);
    if (current === newStr) return;

    var front = digitEl.querySelector('.flap.front');
    var back  = digitEl.querySelector('.flap.back');
    var under = digitEl.querySelector('.flap.under');

    front.setAttribute('data-content', current);
    back.setAttribute('data-content', newStr);
    under.setAttribute('data-content', newStr);

    [front, back, under].forEach(function(f) {
      f.style.animation = 'none';
      f.style.display = 'block';
    });
    requestAnimationFrame(function() {
      requestAnimationFrame(function() {
        [front, back, under].forEach(function(f) { f.style.animation = ''; });
      });
    });
    setTimeout(function() {
      base.textContent = newStr;
      [front, back, under].forEach(function(f) { f.style.display = 'none'; });
    }, 350);
  }

  function jumpTo(digitEl, num) {
    digitEl.querySelector('.base').textContent = String(num);
  }

  function updateGroup(group, value, flip) {
    var str = String(value).padStart(2, '0');
    var d1 = document.querySelector('.ten' + group);
    var d2 = document.querySelector('.' + group);
    if (!d1 || !d2) return;
    flip ? (flipTo(d1, str[0]), flipTo(d2, str[1]))
         : (jumpTo(d1, str[0]), jumpTo(d2, str[1]));
  }

  function tick(flip) {
    var diff = targetDate - new Date().getTime();
    if (diff <= 0) {
      updateGroup('day',  0, flip);
      updateGroup('hour', 0, flip);
      updateGroup('min',  0, flip);
      updateGroup('sec',  0, flip);
      return;
    }
    updateGroup('day',  Math.floor(diff / 86400000), flip);
    updateGroup('hour', Math.floor((diff % 86400000) / 3600000), flip);
    updateGroup('min',  Math.floor((diff % 3600000) / 60000), flip);
    updateGroup('sec',  Math.floor((diff % 60000) / 1000), flip);
  }

  tick(false);
  setInterval(function() { tick(true); }, 1000);
})();
</script>
