}
.clock .digit:last-child {
  margin-right: 0;
}
.clock-wrapper {
  position: relative;
  overflow: hidden;
  height: 85vh;
  display: flex;
  flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 10%;
}
.clock-wrapper__video {
  position: absolute;
  top: 50%;
  left: 50%;
  width: 100vw;
  height: 56.25vw;
  min-height: 100%;
  min-width: 177.77vh;
  transform: translate(-50%, -50%);
  pointer-events: none;
  z-index: 0;
