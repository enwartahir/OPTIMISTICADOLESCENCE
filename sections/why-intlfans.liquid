{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: calc({{ section.settings.padding_top }}px * 0.75);
    padding-bottom: calc({{ section.settings.padding_bottom }}px * 0.75);
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .why-intlfans-{{ section.id }} {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .why-intlfans-{{ section.id }} .why__image-wrap {
    position: relative;
    border-radius: 1.2rem;
    overflow: hidden;
  }

  .why-intlfans-{{ section.id }} .why__image-wrap img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 4/5;
    min-height: 300px;
  }

  .why-intlfans-{{ section.id }} .why__content {
    display: flex;
    flex-direction: column;
    gap: 2.4rem;
  }

  .why-intlfans-{{ section.id }} .why__eyebrow {
    font-size: 1.2rem;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    opacity: 0.6;
  }

  .why-intlfans-{{ section.id }} .why__heading {
    font-size: 3.6rem;
    font-weight: 800;
    line-height: 1.1;
    margin: 0;
  }

  .why-intlfans-{{ section.id }} .why__story {
    font-size: 1.55rem;
    line-height: 1.7;
    opacity: 0.85;
    margin: 0;
  }

  .why-intlfans-{{ section.id }} .why__trust-points {
    display: flex;
    flex-direction: column;
    gap: 2rem;
    margin-top: 0.8rem;
  }

  .why-intlfans-{{ section.id }} .why__trust-item {
    display: flex;
    gap: 1.6rem;
    align-items: flex-start;
  }

  .why-intlfans-{{ section.id }} .why__trust-icon {
    font-size: 2.4rem;
    line-height: 1;
    flex-shrink: 0;
    width: 4rem;
    height: 4rem;
    display: flex;
    align-items: center;
    justify-content: center;
    background: rgba(var(--color-foreground), 0.06);
    border-radius: 0.8rem;
  }

  .why-intlfans-{{ section.id }} .why__trust-text h4 {
    font-size: 1.5rem;
    font-weight: 700;
    margin: 0 0 0.4rem;
  }

  .why-intlfans-{{ section.id }} .why__trust-text p {
    font-size: 1.35rem;
    line-height: 1.6;
    opacity: 0.75;
    margin: 0;
  }

  .why-intlfans-{{ section.id }} .why__cta {
    margin-top: 1.2rem;
  }

  .why-intlfans-{{ section.id }} .why__cta a {
    display: inline-flex;
    align-items: center;
    gap: 0.8rem;
    padding: 1.4rem 3.2rem;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    font-size: 1.4rem;
    font-weight: 700;
    letter-spacing: 0.05em;
    text-transform: uppercase;
    text-decoration: none;
    border-radius: 0.6rem;
    transition: opacity 0.2s ease;
  }

  .why-intlfans-{{ section.id }} .why__cta a:hover {
    opacity: 0.85;
  }

  @media screen and (max-width: 989px) {
    .why-intlfans-{{ section.id }} {
      grid-template-columns: 1fr;
      gap: 4rem;
    }

    .why-intlfans-{{ section.id }} .why__heading {
      font-size: 2.8rem;
    }

    .why-intlfans-{{ section.id }} .why__image-wrap img {
      aspect-ratio: 16/9;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="why-intlfans-{{ section.id }}">

      {%- if section.settings.image != blank -%}
        <div class="why__image-wrap {% if section.settings.image_position == 'right' %}why__image--right{% endif %}">
          {{
            section.settings.image
            | image_url: width: 1200
            | image_tag:
              loading: 'lazy',
              widths: '600, 900, 1200',
              sizes: '(min-width: 990px) 50vw, 100vw',
              alt: section.settings.image.alt | escape
          }}
        </div>
      {%- endif -%}

      <div class="why__content {% if section.settings.image_position == 'right' %}why__content--first{% endif %}">

        {%- if section.settings.eyebrow != blank -%}
          <p class="why__eyebrow">{{ section.settings.eyebrow }}</p>
        {%- endif -%}

        {%- if section.settings.heading != blank -%}
          <h2 class="why__heading">{{ section.settings.heading }}</h2>
        {%- endif -%}

        {%- if section.settings.story != blank -%}
          <p class="why__story">{{ section.settings.story }}</p>
        {%- endif -%}

        <div class="why__trust-points">
          {%- for block in section.blocks -%}
            {%- if block.type == 'trust_point' -%}
              <div class="why__trust-item" {{ block.shopify_attributes }}>
                {%- if block.settings.icon != blank -%}
                  <div class="why__trust-icon">{{ block.settings.icon }}</div>
                {%- endif -%}
                <div class="why__trust-text">
                  {%- if block.settings.title != blank -%}
                    <h4>{{ block.settings.title }}</h4>
                  {%- endif -%}
                  {%- if block.settings.text != blank -%}
                    <p>{{ block.settings.text }}</p>
                  {%- endif -%}
                </div>
              </div>
            {%- endif -%}
          {%- endfor -%}
        </div>

        {%- if section.settings.button_label != blank -%}
          <div class="why__cta">
            <a href="{{ section.settings.button_link }}">
              {{ section.settings.button_label }}
              <span>→</span>
            </a>
          </div>
        {%- endif -%}

      </div>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Why IntlFans",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Image Position",
      "options": [
        { "value": "left", "label": "Left" },
        { "value": "right", "label": "Right" }
      ],
      "default": "left"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow Text",
      "default": "Our Story"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Why IntlFans?"
    },
    {
      "type": "textarea",
      "id": "story",
      "label": "Story Text",
      "default": "IntlFans was built by football fans who were tired of overpaying for jerseys that took weeks to arrive. We wanted one place — built for international football fans — where you could find your nation's colors, trust the quality, and get it fast. From Buenos Aires to Berlin, football is the one language the entire world speaks."
    },
    {
      "type": "text",
      "id": "button_label",
      "label": "Button Label",
      "default": "Shop Now — Find Your Jersey"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Button Link"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "blocks": [
    {
      "type": "trust_point",
      "name": "Trust Point",
      "settings": [
        {
          "type": "text",
          "id": "icon",
          "label": "Icon (emoji)",
          "default": "🌍"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Official Replica Jerseys"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Description",
          "default": "Every jersey manufactured by the same brands that kit out the world's greatest national teams. adidas. Nike. Puma. The real deal."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Why IntlFans",
      "blocks": [
        {
          "type": "trust_point",
          "settings": {
            "icon": "🌍",
            "title": "Official Replica Jerseys",
            "text": "Every jersey manufactured by adidas, Nike and Puma — the same brands that kit out the world's greatest national teams."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "icon": "⚡",
            "title": "Fast Worldwide Shipping",
            "text": "We ship to football fans everywhere. Wherever you are in the world, your jersey is on its way."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "icon": "🔒",
            "title": "Secure & Safe Checkout",
            "text": "Shop with complete confidence. Every transaction is protected with industry standard encryption."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "icon": "🏆",
            "title": "Built by Fans, For Fans",
            "text": "Every product we carry is chosen by people who actually care about the beautiful game."
          }
        },
        {
          "type": "trust_point",
          "settings": {
            "icon": "↩️",
            "title": "Hassle-Free Returns",
            "text": "Not the right size? No problem. Easy returns, no questions asked."
          }
        }
      ]
    }
  ]
}
{% endschema %}