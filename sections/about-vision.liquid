{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .about-vision__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .about-vision__image {
    order: 2;
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .about-vision__image img {
    width: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 4/5;
  }

  .about-vision__content {
    order: 1;
  }

  .about-vision__label {
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.5;
    margin-bottom: 1.2rem;
  }

  .about-vision__heading {
    font-size: 3.6rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .about-vision__text {
    font-size: 1.6rem;
    line-height: 1.8;
    opacity: 0.75;
    margin-bottom: 2.4rem;
  }

  .about-vision__pillars {
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .about-vision__pillar {
    display: flex;
    align-items: center;
    gap: 1.6rem;
    padding: 1.6rem 2rem;
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 6px;
  }

  .about-vision__pillar-icon {
    font-size: 2rem;
    flex-shrink: 0;
  }

  .about-vision__pillar-text {
    font-size: 1.4rem;
    font-weight: 600;
    line-height: 1.5;
  }

  @media screen and (max-width: 749px) {
    .about-vision__inner {
      grid-template-columns: 1fr;
      gap: 3.2rem;
    }
    .about-vision__image { order: 1; }
    .about-vision__content { order: 2; }
    .about-vision__heading { font-size: 2.6rem; }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="about-vision__inner">

      <div class="about-vision__content">
        <p class="about-vision__label">💙 Our Vision</p>
        <h2 class="about-vision__heading">More Than a Store</h2>
        <p class="about-vision__text">We're building more than a store — we're building a community of fans worldwide. A place where passion meets style, culture meets sport, and fans become part of something bigger than a single jersey.</p>

        <div class="about-vision__pillars">
          <div class="about-vision__pillar">
            <span class="about-vision__pillar-icon">❤️</span>
            <span class="about-vision__pillar-text">Passion meets style — wear what you feel</span>
          </div>
          <div class="about-vision__pillar">
            <span class="about-vision__pillar-icon">🌍</span>
            <span class="about-vision__pillar-text">Culture meets sport — football is a lifestyle</span>
          </div>
          <div class="about-vision__pillar">
            <span class="about-vision__pillar-icon">🤝</span>
            <span class="about-vision__pillar-text">Fans become community — you're not alone in this</span>
          </div>
        </div>
      </div>

      <div class="about-vision__image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1000 | image_tag: loading: 'lazy', widths: '500, 800, 1000' }}
        {%- else -%}
          {{ 'lifestyle-2' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "About — Vision",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [{ "name": "About — Vision" }]
}
{% endschema %}