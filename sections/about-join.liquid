{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .about-join__wrapper {
    position: relative;
    border-radius: 12px;
    overflow: hidden;
    min-height: 480px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .about-join__bg {
    position: absolute;
    inset: 0;
    z-index: 0;
  }

  .about-join__bg img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .about-join__overlay {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.65);
    z-index: 1;
  }

  .about-join__content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: #fff;
    padding: 6rem 3rem;
    max-width: 700px;
  }

  .about-join__label {
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.65;
    margin-bottom: 1.6rem;
    display: block;
  }

  .about-join__heading {
    font-size: 4.8rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.05;
    margin-bottom: 2rem;
    color: #fff;
  }

  .about-join__text {
    font-size: 1.7rem;
    line-height: 1.7;
    opacity: 0.85;
    margin-bottom: 3.2rem;
  }

  .about-join__cta {
    display: inline-flex;
    align-items: center;
    padding: 1.6rem 4rem;
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: #fff;
    color: #111;
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .about-join__cta:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .about-join__heading { font-size: 3rem; }
    .about-join__wrapper { min-height: 400px; }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="about-join__wrapper">

      {%- if section.settings.image != blank -%}
        <div class="about-join__bg">
          {{ section.settings.image | image_url: width: 2000 | image_tag: loading: 'lazy', widths: '750, 1200, 2000' }}
        </div>
      {%- endif -%}

      <div class="about-join__overlay"></div>

      <div class="about-join__content">
        <span class="about-join__label">🙌 Join the Movement</span>
        <h2 class="about-join__heading">Don't Just Watch the Game. Live It.</h2>
        <p class="about-join__text">INTLFans is for those who wear their passion, carry their culture, and show up for their nation every single time. From Cape Coral to every corner of the world — this is your jersey, your identity, your moment.</p>
        <a href="{{ section.settings.cta_url }}" class="about-join__cta">
          {{ section.settings.cta_label }} →
        </a>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "About — Join the Movement",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Background Image"
    },
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "Shop All Jerseys"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [{ "name": "About — Join the Movement" }]
}
{% endschema %}