{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .about-diff__heading-wrap {
    text-align: center;
    margin-bottom: 5rem;
  }

  .about-diff__label {
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.5;
    margin-bottom: 1.2rem;
  }

  .about-diff__heading {
    font-size: 3.6rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.1;
    margin-bottom: 1.2rem;
  }

  .about-diff__subtext {
    font-size: 1.6rem;
    opacity: 0.65;
    max-width: 560px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .about-diff__grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 2.4rem;
  }

  .about-diff__card {
    padding: 3.2rem;
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    gap: 1.2rem;
  }

  .about-diff__card-icon {
    font-size: 2.8rem;
  }

  .about-diff__card-title {
    font-size: 1.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
  }

  .about-diff__card-text {
    font-size: 1.4rem;
    opacity: 0.65;
    line-height: 1.7;
  }

  @media screen and (max-width: 749px) {
    .about-diff__grid {
      grid-template-columns: 1fr;
    }
    .about-diff__heading {
      font-size: 2.6rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">

    <div class="about-diff__heading-wrap">
      <p class="about-diff__label">⚽ What Makes Us Different</p>
      <h2 class="about-diff__heading">Beyond the Jersey</h2>
      <p class="about-diff__subtext">At INTLFans, we go beyond just selling jerseys. We curate, we style, we deliver — for the new generation of fans.</p>
    </div>

    <div class="about-diff__grid">

      <div class="about-diff__card">
        <span class="about-diff__card-icon">✨</span>
        <h3 class="about-diff__card-title">Curated Selection</h3>
        <p class="about-diff__card-text">We handpick the most in-demand and iconic jerseys — including rare, trending, and international designs that you won't find just anywhere.</p>
      </div>

      <div class="about-diff__card">
        <span class="about-diff__card-icon">💎</span>
        <h3 class="about-diff__card-title">Premium Feel Without the Premium Price</h3>
        <p class="about-diff__card-text">We focus on delivering quality, comfort, and style — while keeping it accessible. Official replica quality at a price that makes sense for fans.</p>
      </div>

      <div class="about-diff__card">
        <span class="about-diff__card-icon">👟</span>
        <h3 class="about-diff__card-title">Fashion Meets Football</h3>
        <p class="about-diff__card-text">Our jerseys are not just for game day — they're made to be styled, worn, and seen. Wear your colors on the pitch, the street, or wherever life takes you.</p>
      </div>

      <div class="about-diff__card">
        <span class="about-diff__card-icon">🔥</span>
        <h3 class="about-diff__card-title">Built for the New Generation</h3>
        <p class="about-diff__card-text">We understand modern culture — blending sports, fashion, and lifestyle into one brand. INTLFans is for fans who don't just watch the game. They live it.</p>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "About — Different",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [{ "name": "About — Different" }]
}
{% endschema %}