{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .aff-hero__wrapper {
    text-align: center;
    max-width: 720px;
    margin: 0 auto;
  }

  .aff-hero__label {
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.5;
    margin-bottom: 1.6rem;
    display: block;
  }

  .aff-hero__heading {
    font-size: 5rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.05;
    margin-bottom: 2rem;
  }

  .aff-hero__subtext {
    font-size: 1.8rem;
    line-height: 1.7;
    opacity: 0.7;
    margin-bottom: 3.2rem;
  }

  .aff-hero__cta {
    display: inline-flex;
    align-items: center;
    padding: 1.6rem 4rem;
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.2s ease;
  }

  .aff-hero__cta:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .aff-hero__heading { font-size: 3.2rem; }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="aff-hero__wrapper">
      <span class="aff-hero__label">⚽ INTLFans Affiliate Program</span>
      <h1 class="aff-hero__heading">Earn With Every Jersey You Sell</h1>
      <p class="aff-hero__subtext">Join the INTLFans Affiliate Program and turn your passion for football into real income. Share your unique link, drive sales, and get paid — it's that simple.</p>
      <a href="{{ section.settings.cta_url }}" class="aff-hero__cta">
        {{ section.settings.cta_label }} →
      </a>
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Affiliates — Hero",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "url",
      "id": "cta_url",
      "label": "Button Link"
    },
    {
      "type": "text",
      "id": "cta_label",
      "label": "Button Label",
      "default": "Apply Now"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 80
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [{ "name": "Affiliates — Hero" }]
}
{% endschema %}