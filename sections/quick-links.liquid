{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .quick-links-grid__heading {
    font-size: 3.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 1.2rem;
    text-align: center;
  }

  .quick-links-grid__subtext {
    font-size: 1.5rem;
    opacity: 0.65;
    line-height: 1.7;
    margin-bottom: 5rem;
    text-align: center;
    max-width: 560px;
    margin-left: auto;
    margin-right: auto;
  }

  .quick-links-grid__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2.4rem;
  }

  .quick-links-grid__card {
    padding: 3.2rem 2.8rem;
    border: 1px solid rgba(var(--color-foreground), 0.1);
    border-radius: 8px;
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 1.2rem;
  }

  .quick-links-grid__card-icon {
    font-size: 3.2rem;
    display: block;
  }

  .quick-links-grid__card-title {
    font-size: 1.8rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    margin: 0;
  }

  .quick-links-grid__card-text {
    font-size: 1.4rem;
    opacity: 0.65;
    line-height: 1.7;
    flex: 1;
  }

  .quick-links-grid__card-cta {
    display: inline-flex;
    align-items: center;
    padding: 1.2rem 2.4rem;
    font-size: 1.3rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border-radius: 4px;
    text-decoration: none;
    transition: opacity 0.2s ease;
    margin-top: 0.8rem;
  }

  .quick-links-grid__card-cta:hover {
    opacity: 0.85;
    text-decoration: none;
  }

  @media screen and (max-width: 749px) {
    .quick-links-grid__grid {
      grid-template-columns: 1fr;
    }

    .quick-links-grid__heading {
      font-size: 2.4rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">

    {%- if section.settings.heading != blank -%}
      <h2 class="quick-links-grid__heading">{{ section.settings.heading }}</h2>
    {%- endif -%}

    {%- if section.settings.subtext != blank -%}
      <p class="quick-links-grid__subtext">{{ section.settings.subtext }}</p>
    {%- endif -%}

    <div class="quick-links-grid__grid">

      <!-- Card 1: Shipping Timeline -->
      <div class="quick-links-grid__card">
        <span class="quick-links-grid__card-icon">✈️</span>
        <h3 class="quick-links-grid__card-title">{{ section.settings.card1_title }}</h3>
        <p class="quick-links-grid__card-text">{{ section.settings.card1_text }}</p>
        {%- if section.settings.card1_url != blank -%}
          <a href="{{ section.settings.card1_url }}" class="quick-links-grid__card-cta">
            {{ section.settings.card1_cta }} →
          </a>
        {%- endif -%}
      </div>

      <!-- Card 2: Size Guide -->
      <div class="quick-links-grid__card">
        <span class="quick-links-grid__card-icon">📏</span>
        <h3 class="quick-links-grid__card-title">{{ section.settings.card2_title }}</h3>
        <p class="quick-links-grid__card-text">{{ section.settings.card2_text }}</p>
        {%- if section.settings.card2_url != blank -%}
          <a href="{{ section.settings.card2_url }}" class="quick-links-grid__card-cta">
            {{ section.settings.card2_cta }} →
          </a>
        {%- endif -%}
      </div>

      <!-- Card 3: Browse Jerseys -->
      <div class="quick-links-grid__card">
        <span class="quick-links-grid__card-icon">🏆</span>
        <h3 class="quick-links-grid__card-title">{{ section.settings.card3_title }}</h3>
        <p class="quick-links-grid__card-text">{{ section.settings.card3_text }}</p>
        {%- if section.settings.card3_url != blank -%}
          <a href="{{ section.settings.card3_url }}" class="quick-links-grid__card-cta">
            {{ section.settings.card3_cta }} →
          </a>
        {%- endif -%}
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Quick Links Grid",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Before You Go"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "You might find what you're looking for right here."
    },
    {
      "type": "header",
      "content": "Card 1 — Shipping Timeline"
    },
    {
      "type": "text",
      "id": "card1_title",
      "label": "Title",
      "default": "Shipping Timeline"
    },
    {
      "type": "textarea",
      "id": "card1_text",
      "label": "Description",
      "default": "Wondering when your jersey will arrive? Check our full shipping timeline to see exactly what happens from the moment you place your order to delivery at your door."
    },
    {
      "type": "url",
      "id": "card1_url",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "card1_cta",
      "label": "Button Label",
      "default": "View Timeline"
    },
    {
      "type": "header",
      "content": "Card 2 — Size Guide"
    },
    {
      "type": "text",
      "id": "card2_title",
      "label": "Title",
      "default": "Size Guide"
    },
    {
      "type": "textarea",
      "id": "card2_text",
      "label": "Description",
      "default": "Not sure which size to order? Our size guide breaks down chest, waist and hip measurements so you can find the perfect fit before you buy."
    },
    {
      "type": "url",
      "id": "card2_url",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "card2_cta",
      "label": "Button Label",
      "default": "View Size Guide"
    },
    {
      "type": "header",
      "content": "Card 3 — Browse Jerseys"
    },
    {
      "type": "text",
      "id": "card3_title",
      "label": "Title",
      "default": "Browse Jerseys"
    },
    {
      "type": "textarea",
      "id": "card3_text",
      "label": "Description",
      "default": "From Argentina to Germany, we carry official replica jerseys for the world's greatest national teams. Find yours before the World Cup 2026."
    },
    {
      "type": "url",
      "id": "card3_url",
      "label": "Link"
    },
    {
      "type": "text",
      "id": "card3_cta",
      "label": "Button Label",
      "default": "Shop All Jerseys"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Quick Links Grid"
    }
  ]
}
{% endschema %}