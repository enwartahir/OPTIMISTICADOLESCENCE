{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .order-tracking__wrapper {
    max-width: 560px;
    margin: 0 auto;
    text-align: center;
  }

  .order-tracking__icon {
    font-size: 4rem;
    margin-bottom: 1.6rem;
    display: block;
  }

  .order-tracking__heading {
    font-size: 3.2rem;
    font-weight: 800;
    text-transform: uppercase;
    letter-spacing: 0.03em;
    margin-bottom: 1.2rem;
  }

  .order-tracking__subtext {
    font-size: 1.5rem;
    opacity: 0.65;
    line-height: 1.7;
    margin-bottom: 4rem;
  }

  .order-tracking__form {
    display: flex;
    flex-direction: column;
    gap: 1.6rem;
  }

  .order-tracking__field {
    display: flex;
    flex-direction: column;
    text-align: left;
    gap: 0.6rem;
  }

  .order-tracking__label {
    font-size: 1.3rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    opacity: 0.7;
  }

  .order-tracking__input {
    width: 100%;
    padding: 1.4rem 1.6rem;
    font-size: 1.5rem;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 4px;
    background: transparent;
    color: rgb(var(--color-foreground));
    transition: border-color 0.2s ease;
    box-sizing: border-box;
  }

  .order-tracking__input:focus {
    outline: none;
    border-color: rgb(var(--color-foreground));
  }

  .order-tracking__input::placeholder {
    opacity: 0.4;
  }

  .order-tracking__submit {
    width: 100%;
    padding: 1.6rem;
    font-size: 1.5rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    background: rgb(var(--color-button));
    color: rgb(var(--color-button-text));
    border: none;
    border-radius: 4px;
    cursor: pointer;
    transition: opacity 0.2s ease;
    margin-top: 0.8rem;
  }

  .order-tracking__submit:hover {
    opacity: 0.85;
  }

  .order-tracking__note {
    font-size: 1.2rem;
    opacity: 0.5;
    margin-top: 2rem;
    line-height: 1.6;
  }

  @media screen and (max-width: 749px) {
    .order-tracking__heading {
      font-size: 2.4rem;
    }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="order-tracking__wrapper">

      <span class="order-tracking__icon">📦</span>
      <h1 class="order-tracking__heading">{{ section.settings.heading }}</h1>
      <p class="order-tracking__subtext">{{ section.settings.subtext }}</p>

      <form class="order-tracking__form" action="/tools/track" method="get">
        <div class="order-tracking__field">
          <label class="order-tracking__label" for="OrderTrackingNumber">Order Number</label>
          <input
            class="order-tracking__input"
            type="text"
            id="OrderTrackingNumber"
            name="order"
            placeholder="e.g. 1001"
            required
          >
        </div>
        <div class="order-tracking__field">
          <label class="order-tracking__label" for="OrderTrackingEmail">Email Address</label>
          <input
            class="order-tracking__input"
            type="email"
            id="OrderTrackingEmail"
            name="email"
            placeholder="e.g. yourname@email.com"
            required
          >
        </div>
        <button type="submit" class="order-tracking__submit">
          Track My Order →
        </button>
      </form>

      <p class="order-tracking__note">
        Your order number can be found in your confirmation email from INTLFans. If you need help, contact us directly.
      </p>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "Order Tracking",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Track Your Order"
    },
    {
      "type": "text",
      "id": "subtext",
      "label": "Subtext",
      "default": "Enter your order number and email address below to track the status of your delivery."
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [
    {
      "name": "Order Tracking"
    }
  ]
}
{% endschema %}