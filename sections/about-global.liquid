{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }
  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .about-global__inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 6rem;
    align-items: center;
  }

  .about-global__image {
    width: 100%;
    border-radius: 8px;
    overflow: hidden;
  }

  .about-global__image img {
    width: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 16/10;
  }

  .about-global__label {
    font-size: 1.2rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.15em;
    opacity: 0.5;
    margin-bottom: 1.2rem;
  }

  .about-global__heading {
    font-size: 3.6rem;
    font-weight: 800;
    text-transform: uppercase;
    line-height: 1.1;
    margin-bottom: 2rem;
  }

  .about-global__text {
    font-size: 1.6rem;
    line-height: 1.8;
    opacity: 0.75;
    margin-bottom: 1.6rem;
  }

  .about-global__tag {
    display: inline-block;
    padding: 0.8rem 1.6rem;
    border: 1px solid rgba(var(--color-foreground), 0.2);
    border-radius: 100px;
    font-size: 1.3rem;
    font-weight: 600;
    margin-top: 1.6rem;
  }

  @media screen and (max-width: 749px) {
    .about-global__inner {
      grid-template-columns: 1fr;
      gap: 3.2rem;
    }
    .about-global__heading { font-size: 2.6rem; }
  }
{%- endstyle -%}

<div class="color-{{ section.settings.color_scheme }} gradient">
  <div class="section-{{ section.id }}-padding page-width">
    <div class="about-global__inner">

      <div class="about-global__image">
        {%- if section.settings.image != blank -%}
          {{ section.settings.image | image_url: width: 1200 | image_tag: loading: 'lazy', widths: '600, 900, 1200' }}
        {%- else -%}
          {{ 'lifestyle-1' | placeholder_svg_tag: 'placeholder-svg' }}
        {%- endif -%}
      </div>

      <div>
        <p class="about-global__label">🌎 Global Game. Local Roots.</p>
        <h2 class="about-global__heading">Cape Coral to the World</h2>
        <p class="about-global__text">Proudly based in Cape Coral, Florida, we are inspired by the global energy of football. From the World Cup to local matches, from Europe to South America — we bring the world of football to your wardrobe.</p>
        <p class="about-global__text">We ship to fans in over 150 countries because football has no borders. Whether you're in Miami watching a Copa América final or in London watching the Premier League — your jersey ships from us to you, tracked every step of the way.</p>
        <span class="about-global__tag">📍 Cape Coral, Florida → 150+ Countries</span>
      </div>

    </div>
  </div>
</div>

{% schema %}
{
  "name": "About — Global Roots",
  "tag": "section",
  "class": "section",
  "settings": [
    {
      "type": "image_picker",
      "id": "image",
      "label": "Image"
    },
    {
      "type": "color_scheme",
      "id": "color_scheme",
      "label": "Color Scheme",
      "default": "scheme-1"
    },
    {
      "type": "header",
      "content": "Padding"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Top",
      "default": 60
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding Bottom",
      "default": 60
    }
  ],
  "presets": [{ "name": "About — Global Roots" }]
}
{% endschema %}