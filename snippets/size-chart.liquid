<style>
  .size-chart-table {
    width: 100%;
    border-collapse: collapse;
    font-family: inherit;
    font-size: 1.4rem;
  }
.size-chart-table thead tr th {
   
    color: #000000;
  }
  .size-chart-table thead tr {
    background: #111;
    color: #fff;
  }
  .size-chart-table th {
    padding: 10px 20px;
    text-align: center;
    font-weight: 700;
    text-transform: uppercase;
    white-space: nowrap;
  }
  .size-chart-table th:first-child {
    text-align: left;
  }
  .size-chart-table td {
    padding: 10px 20px;
    text-align: center;
    white-space: nowrap;
    font-weight: 700;
    font-size: 1.2rem;
  }
  .size-chart-table td:first-child {
    text-align: left;
    font-weight: 600;
    font-size: 1.4rem;
  }
  .size-chart-table .block-header td {
    background: #ffffff;
    font-weight: 700;
    font-size: 1.2rem;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: #333;
    padding: 10px 20px;
    text-align: left;
  }
  .size-chart-table tr:nth-child(even) {
    background: #3e69b20f;
  }
  .size-chart-table tr:nth-child(odd) {
    background: #fff;
  }
  .size-chart-table .block-header {
    background: #3e69b20f !important;
  }
  .size-chart-heading {
    font-size: 1.6rem;
    font-weight: 700;
    text-transform: uppercase;
    margin-bottom: 12px;
  }
  .size-chart-note {
    text-align: center;
    font-size: 1.2rem;
    color: #444;
    margin-top: 14px;
    line-height: 1.6;
  }
  .size-chart-wrapper {
    overflow-x: auto;
    width: 100%;
  }
</style>
<div class="size-chart-wrapper">
  <table class="size-chart-table">
    <thead>
      <tr>
        <th>Size</th>
        <th>Chest</th>
        <th>Waist</th>
        <th>Hip</th>
      </tr>
    </thead>
    <tbody>
      <tr>
        <td>S</td>
        <td>87 - 92</td>
        <td>75 - 80</td>
        <td>86 - 91</td>
      </tr>
      <tr>
        <td>M</td>
        <td>93 - 100</td>
        <td>81 - 88</td>
        <td>92 - 99</td>
      </tr>
      <tr>
        <td>L</td>
        <td>101 - 108</td>
        <td>89 - 96</td>
        <td>100 - 107</td>
      </tr>
      <tr>
        <td>XL</td>
        <td>109 - 118</td>
        <td>97 - 106</td>
        <td>108 - 116</td>
      </tr>
    </tbody>
  </table>
</div>
<p class="size-chart-note">
  Measurements are in centimeters and may vary slightly. Chest is measured around the fullest part, waist around the natural waistline, and hip around the fullest part of the hips.
</p>